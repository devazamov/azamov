rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isMember(chat) {
      return signedIn() && request.auth.uid in chat.data.members;
    }

    // Foydalanuvchi profillari: hamma o'qiy oladi (qidiruv uchun),
    // faqat egasi o'zinikini yozadi.
    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Chatlar: faqat a'zolar o'qiydi/yangilaydi.
    match /chats/{chatId} {
      allow read: if isMember(resource);
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;
      allow update: if isMember(resource);
      allow delete: if false;

      // Xabarlar: faqat chat a'zolari.
      match /messages/{messageId} {
        allow read: if isMember(get(/databases/$(database)/documents/chats/$(chatId)));
        allow create: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
